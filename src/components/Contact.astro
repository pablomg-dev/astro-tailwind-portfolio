---
/**
 * Sección de Contacto con formulario de Netlify
 */
interface Props {
  title: string;
  subtitle: string;
  nameLabel: string;
  emailLabel: string;
  messageLabel: string;
  sendButton: string;
  successMessage: string;
}

const { title, subtitle, nameLabel, emailLabel, messageLabel, sendButton, successMessage } = Astro.props;
---

<section class="py-20 relative" id="contact">
  <div class="absolute inset-0 bg-primary/5 blur-[80px] -z-10"></div>
  
  <div class="text-center mb-16">
    <h2
      class="text-4xl font-serif text-cream mb-4 tracking-widest uppercase opacity-0 translate-y-16 transition-all duration-1000"
      data-scroll-animation
    >
      {title}
    </h2>
    <p 
      class="text-cream/60 font-light opacity-0 translate-y-16 transition-all duration-1000 delay-200"
      data-scroll-animation
    >
      {subtitle}
    </p>
  </div>

  <div 
    class="max-w-xl mx-auto bg-midnight/40 backdrop-blur-xl border border-primary/10 p-8 rounded-3xl shadow-aura-lg opacity-0 translate-y-16 transition-all duration-1000 delay-300"
    data-scroll-animation
  >
    <form
      name="contact"
      method="POST"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
      action="/"
      class="space-y-6"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden">
        <label>Don't fill this out if you're human: <input name="bot-field" /></label>
      </p>
      
      <div>
        <label for="name" class="block text-sm font-medium text-cream/80 mb-2 ml-1">
          {nameLabel}
        </label>
        <input
          type="text"
          name="name"
          id="name"
          required
          autocomplete="name"
          class="w-full bg-space/50 border border-primary/10 rounded-2xl px-5 py-4 text-cream focus:ring-2 focus:ring-primary/20 focus:border-primary/30 outline-none transition-all duration-300"
          placeholder="Tu nombre"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-cream/80 mb-2 ml-1">
          {emailLabel}
        </label>
        <input
          type="email"
          name="email"
          id="email"
          required
          autocomplete="email"
          class="w-full bg-space/50 border border-primary/10 rounded-2xl px-5 py-4 text-cream focus:ring-2 focus:ring-primary/20 focus:border-primary/30 outline-none transition-all duration-300"
          placeholder="tu@email.com"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-cream/80 mb-2 ml-1">
          {messageLabel}
        </label>
        <textarea
          name="message"
          id="message"
          rows="5"
          required
          class="w-full bg-space/50 border border-primary/10 rounded-2xl px-5 py-4 text-cream focus:ring-2 focus:ring-primary/20 focus:border-primary/30 outline-none transition-all duration-300 resize-none"
          placeholder="¿En qué puedo ayudarte?"
        ></textarea>
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full bg-primary/10 hover:bg-primary/20 border border-primary/20 text-primary font-serif text-lg py-4 rounded-2xl transition-all duration-500 hover:shadow-aura group flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <span id="btn-text">{sendButton}</span>
        <svg 
          id="btn-icon"
          xmlns="http://www.w3.org/2000/svg" 
          width="20" 
          height="20" 
          viewBox="0 0 24 24" 
          fill="none" 
          stroke="currentColor" 
          stroke-width="2" 
          stroke-linecap="round" 
          stroke-linejoin="round" 
          class="group-hover:translate-x-1 transition-transform"
        >
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </form>

    <div 
      id="form-success" 
      class="hidden mt-6 p-6 bg-primary/10 border border-primary/20 rounded-2xl text-primary text-center font-light animate-in fade-in zoom-in duration-500"
      role="status"
      aria-live="polite"
      tabindex="-1"
    >
      <div class="flex flex-col items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>
        <p class="text-lg">{successMessage}</p>
      </div>
    </div>

    <div 
      id="form-error" 
      class="hidden mt-6 p-6 bg-red-500/10 border border-red-500/20 rounded-2xl text-red-400 text-center font-light animate-in fade-in zoom-in duration-500"
      role="alert"
      aria-live="assertive"
      tabindex="-1"
    >
      <div class="flex flex-col items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-red-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-red-400">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </div>
        <p class="text-lg">Hubo un error al enviar el mensaje. Por favor, inténtalo de nuevo.</p>
      </div>
    </div>
  </div>
</section>

<script>
  function initContact() {
    const form = document.querySelector('form[name="contact"]') as HTMLFormElement;
    const successMsg = document.getElementById('form-success');
    const errorMsg = document.getElementById('form-error');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text');
    const btnIcon = document.getElementById('btn-icon');
    
    if (form && successMsg && errorMsg && submitBtn && btnText) {
      const originalBtnText = btnText.textContent;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Estado de carga
        submitBtn.disabled = true;
        btnText.textContent = "Enviando...";
        if (btnIcon) btnIcon.classList.add('hidden');
        errorMsg.classList.add('hidden');
        
        const formData = new FormData(form);
        
        try {
          const response = await fetch("/", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: new URLSearchParams(formData as any).toString(),
          });
          
          if (response.ok) {
            form.classList.add('hidden');
            successMsg.classList.remove('hidden');
            successMsg.focus();
            successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
          } else {
            throw new Error('Error en el servidor');
          }
        } catch (error) {
          console.error('Error:', error);
          // Restaurar botón y mostrar error
          submitBtn.disabled = false;
          btnText.textContent = originalBtnText;
          if (btnIcon) btnIcon.classList.remove('hidden');
          
          errorMsg.classList.remove('hidden');
          errorMsg.focus();
          errorMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    }

    // Soporte para redirección (legacy)
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('success') === 'true') {
      if (successMsg) {
        successMsg.classList.remove('hidden');
        if (form) form.classList.add('hidden');
      }
    }
  }

  document.addEventListener("astro:page-load", initContact);
</script>
