---
import Section from './Section.astro'
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  title: string
  description: string
  greeting: string
  specialtiesTitle: string
  specialties: string[]
  closing: string
  cta: string
  name: string
  image: ImageMetadata
}

const { title, description, greeting, specialtiesTitle, specialties, closing, cta, name, image } =
  Astro.props

function validateAboutProps(props: Props): asserts props is Props {
  if (!props.title || typeof props.title !== 'string') {
    throw new Error('AboutProps.title es requerido y debe ser una cadena')
  }
  if (!props.description || typeof props.description !== 'string') {
    throw new Error('AboutProps.description es requerido y debe ser una cadena')
  }
  if (!props.greeting || typeof props.greeting !== 'string') {
    throw new Error('AboutProps.greeting es requerido y debe ser una cadena')
  }
  if (!props.specialtiesTitle || typeof props.specialtiesTitle !== 'string') {
    throw new Error('AboutProps.specialtiesTitle es requerido y debe ser una cadena')
  }
  if (!Array.isArray(props.specialties)) {
    throw new Error('AboutProps.specialties debe ser un arreglo')
  }
  if (!props.closing || typeof props.closing !== 'string') {
    throw new Error('AboutProps.closing es requerido y debe ser una cadena')
  }
  if (!props.cta || typeof props.cta !== 'string') {
    throw new Error('AboutProps.cta es requerido y debe ser una cadena')
  }
  if (!props.name || typeof props.name !== 'string') {
    throw new Error('AboutProps.name es requerido y debe ser una cadena')
  }
  if (!props.image) {
    throw new Error('AboutProps.image es requerido')
  }
}

validateAboutProps(Astro.props)

const specialtiesList = [specialtiesTitle, ...specialties, '', closing, cta].join('\n')

const fullText = [greeting, description, specialtiesList].join('\n\n')
---

<Section text={title} href="about">
  <div class="flex gap-12 md:gap-8 flex-col items-center md:flex-row">
    <div
      class="text-cream/90 w-auto text-lg font-light md:pr-5 opacity-0 transition-all duration-1000 translate-y-16 whitespace-pre-line leading-relaxed"
      data-scroll-animation
    >
      {fullText}
    </div>
    <div
      class="w-64 h-80 flex-shrink-0 rotate-[2deg] md:rotate-[7deg] opacity-0 transition-all duration-1000 translate-y-16 group hover:shadow-aura hover:-translate-y-1"
      data-scroll-animation
    >
      <Image
        class="object-cover rounded-[2.5rem] shadow-aura-lg border-4 border-midnight w-full h-full transition-all duration-500 group-hover:shadow-aura"
        src={image}
        alt={`Foto de ${name}, desarrollador web freelance en Buenos Aires, Argentina`}
        width={260}
        height={260}
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
</Section>
