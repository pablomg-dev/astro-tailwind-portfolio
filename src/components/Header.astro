---
import Menu from "@icons/Menu.astro";
import AnimatedText from "@components/AnimatedText.astro";
import type { HeaderProps } from "@types";

type Props = HeaderProps;

const { navLinks } = Astro.props;
---

<header
  class="max-w-3xl mx-auto flex items-center justify-between px-5 py-8 relative z-[100] border-b border-sage/10 font-sans"
>
  <a href="/" aria-label="Home link" class="flex items-center">
    <div class="font-serif text-2xl text-cream italic drop-shadow-[0_0_8px_rgba(212,175,55,0.3)]">
      Portales con Propósito
    </div>
  </a>

  <button
    type="button"
    id="menu-button"
    class="sm:hidden text-cream px-4 py-2 transition-colors duration-500 hover:text-primary relative z-[110] cursor-pointer touch-manipulation"
    aria-expanded="false"
    aria-controls="main-menu"
  >
    <div class="pointer-events-none">
      <Menu />
    </div>
  </button>

  <nav
    class="hidden text-cream border absolute right-5 top-24 bg-midnight/90 backdrop-blur-xl border-primary/20 py-6 px-4 rounded-[2rem] sm:block sm:border-0 sm:p-0 sm:static sm:bg-transparent shadow-aura-lg sm:shadow-none z-[100]"
    id="main-menu"
  >
    <ul class="sm:flex gap-4">
      {
        navLinks.map((link) => (
          <li class="relative">
            <a
              class={`font-medium text-base px-4 py-2 block hover:text-primary nav-item transition-all duration-500 text-cream/80 hover:drop-shadow-[0_0_5px_rgba(212,175,55,0.5)]`}
              href={link.href}
              aria-label={`Go to ${link.text}`}
              data-nav-link
            >
              {link.text}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  function initHeader() {
    const button = document.querySelector("#menu-button");
    const menu = document.querySelector("#main-menu");

    if (!button || !menu || (button as any)._initialized) return;
    (button as any)._initialized = true;

    const toggleMenu = () => {
      const isExpanded = button.getAttribute("aria-expanded") === "true";
      if (isExpanded) {
        menu.classList.add("hidden");
        button.setAttribute("aria-expanded", "false");
      } else {
        menu.classList.remove("hidden");
        button.setAttribute("aria-expanded", "true");
      }
    };

    button.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    function smoothScroll(target: string) {
      if (!target) return;
      const element = document.querySelector(target);
      if (!element) return;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      element.scrollIntoView({
        behavior: prefersReducedMotion ? 'auto' : 'smooth',
        block: 'start'
      });
    }

    const links = document.querySelectorAll('a[href^="#"]');
    links.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const target = (e.currentTarget as HTMLAnchorElement).getAttribute("href");
        if (target) {
          smoothScroll(target);
          menu.classList.add("hidden");
          button.setAttribute("aria-expanded", "false");
        }
      });
    });
  }

  // Global document click listener for menu closing
  if (!(window as any)._headerListenerAdded) {
    (window as any)._headerListenerAdded = true;
    document.addEventListener("click", (e) => {
      const menu = document.querySelector("#main-menu");
      const button = document.querySelector("#menu-button");
      if (menu && button) {
        const isHidden = menu.classList.contains("hidden");
        if (!isHidden && !menu.contains(e.target as Node) && !button.contains(e.target as Node)) {
          menu.classList.add("hidden");
          button.setAttribute("aria-expanded", "false");
        }
      }
    }, { passive: true });
  }

  document.addEventListener("astro:page-load", initHeader);
</script>
