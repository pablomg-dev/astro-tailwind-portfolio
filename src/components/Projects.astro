---
/**
 * Sección de proyectos con props traducibles
 */
import type { ProjectProps } from "../types";
import Section from "./Section.astro";
import { Image } from "astro:assets";


interface Props {
  title: string;
  projects: ProjectProps[];
  viewProject: string;
  viewCode: string;
}

const { title, projects, viewProject, viewCode } = Astro.props;
---

<Section text={title} href="projects">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {
      projects.map((project, index) => (
        <div
          class="group relative flex flex-col overflow-hidden rounded-[2rem] bg-midnight/40 backdrop-blur-md transition-all duration-500 hover:shadow-aura hover:bg-midnight/60 opacity-0 translate-y-16 border border-primary/10"
          data-scroll-animation
        >
          <div class="relative aspect-video overflow-hidden">
            <Image
              class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110"
              src={project.image}
              alt={`Proyecto ${project.name} - ${project.summary.split(".")[0]}`}
              width={800}
              height={450}
              loading={index < 2 ? "eager" : "lazy"}
              fetchpriority={index < 2 ? "high" : "auto"}
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#1c1917] via-transparent to-transparent opacity-60" />
          </div>

          <div class="flex flex-col flex-grow p-8">
            <h3 class="text-3xl font-serif mb-4 text-cream transition-colors duration-500 group-hover:text-primary">
              {project.name}
            </h3>
            <p class="text-cream/70 text-base font-light mb-8 flex-grow leading-relaxed">
              {project.summary}
            </p>

            <div class="flex items-center gap-4 mt-auto">
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  class="w-full text-center py-3 rounded-full bg-primary text-midnight text-sm font-semibold transition-all duration-500 hover:scale-105 hover:shadow-aura"
                >
                  {viewProject}
                </a>
              )}
            </div>
          </div>

          <div class="absolute inset-0 z-[-1] opacity-[3%] pointer-events-none bg-[url(/raja.png)] bg-repeat bg-[length:128px]" />
        </div>
      ))
    }
  </div>
</Section>
