---
/**
 * Animated Background with Nebula Blobs (Option 2)
 */
---

<div class="fixed inset-0 overflow-hidden pointer-events-none -z-20 bg-space">
  <!-- Dynamic Nebula Blobs -->
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
  <div class="blob blob-4"></div>

  <!-- Noise Texture for premium feel -->
  <div
    class="absolute inset-0 opacity-[0.03] mix-blend-overlay pointer-events-none bg-[url(/raja.png)] bg-repeat"
  >
  </div>

  <!-- Content Overlay (Gradient) -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-space/20 to-space"></div>
</div>

<style>
  .blob {
    position: absolute;
    width: 70vw;
    height: 70vw;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.25;
    animation: move 20s infinite alternate ease-in-out;
  }

  .blob-1 {
    background: var(--color-nebula, #1a1a3a);
    top: -15%;
    left: -15%;
    animation-duration: 22s;
  }

  .blob-2 {
    background: var(--color-primary, #d4af37);
    bottom: -15%;
    right: -15%;
    width: 60vw;
    height: 60vw;
    opacity: 0.2;
    animation-duration: 18s;
    animation-delay: -5s;
  }

  .blob-3 {
    background: var(--color-sage, #b2ac88);
    top: 30%;
    left: 20%;
    width: 50vw;
    height: 50vw;
    opacity: 0.15;
    animation-duration: 25s;
    animation-delay: -10s;
  }

  .blob-4 {
    background: #4a1a4a;
    bottom: 10%;
    left: -10%;
    width: 55vw;
    height: 55vw;
    opacity: 0.15;
    animation-duration: 20s;
    animation-delay: -15s;
  }

  @keyframes move {
    0% {
      transform: translate(-10%, -10%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(20%, 25%) scale(1.2) rotate(120deg);
    }
    66% {
      transform: translate(-15%, 35%) scale(0.8) rotate(240deg);
    }
    100% {
      transform: translate(10%, -5%) scale(1.1) rotate(360deg);
    }
  }

  /* Support for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .blob {
      animation: none;
    }
  }
</style>
