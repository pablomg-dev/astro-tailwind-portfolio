---
import type { HeroProps } from "../types";

interface Props extends HeroProps {}

const { name, specialty, summary } = Astro.props;
---

<section class="min-h-[85vh] flex flex-col justify-center items-center text-center pt-20 relative w-full overflow-hidden">
  <div class="animate-fade-in w-full px-4" style="animation-delay: 0.2s">
    <h1 class="text-5xl md:text-8xl font-serif text-cream mb-6 drop-shadow-[0_0_15px_rgba(245,245,220,0.3)] leading-tight">
      {name}
    </h1>
    <h2 class="text-2xl md:text-3xl font-sans font-light text-sage tracking-widest uppercase mb-12">
      {specialty}
    </h2>
  </div>

  <div class="max-w-3xl animate-fade-in" style="animation-delay: 0.4s">
    <p class="text-neutral text-xl md:text-2xl font-light leading-relaxed mb-12 italic">
      {summary}
    </p>
  </div>

  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90vw] max-w-[600px] aspect-square bg-primary/10 rounded-full filter blur-[100px] md:blur-[150px] -z-10 animate-pulse-glow"
  >
  </div>
</section>
