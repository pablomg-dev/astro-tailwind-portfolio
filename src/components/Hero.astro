---
/**
 * Sección Hero con información personal
 */
import { Image } from "astro:assets";
import type { HeroProps } from "../types";

interface Props extends HeroProps {}

const { name, specialty, summary, image } = Astro.props;
---

<section
  class="min-h-[85vh] flex flex-col justify-center items-center text-center pt-24 pb-12 relative w-full overflow-hidden"
>
  <div
    class="animate-fade-in w-full px-4 flex flex-col items-center"
    style="animation-delay: 0.2s"
  >
    <div class="relative mb-8 group">

      <Image
        src={image}
        alt={`Foto de ${name}, Desarrollador Web Freelance de habla hispana`}
        width={160}
        height={160}
        loading="eager"
        fetchpriority="high"
        class="relative w-32 h-32 md:w-40 md:h-40 rounded-full border-2 border-primary/30 object-cover shadow-2xl p-1 bg-midnight/50 backdrop-blur-sm"
      />
    </div>

    <h1
      class="text-5xl md:text-8xl font-serif text-cream mb-6 drop-shadow-[0_0_15px_rgba(245,245,220,0.3)] leading-tight"
    >
      {name}
    </h1>
    <h2
      class="text-xl md:text-2xl font-sans font-light text-sage tracking-[0.2em] uppercase mb-10"
    >
      {specialty}
    </h2>
  </div>

  <div class="max-w-2xl animate-fade-in px-6" style="animation-delay: 0.4s">
    <p
      class="text-neutral text-lg md:text-xl font-light leading-relaxed mb-12 italic opacity-80"
    >
      {summary}
    </p>
  </div>

</section>
