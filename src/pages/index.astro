---
import Layout from "@layouts/Layout.astro";
import Hero from "@components/Hero.astro";
import About from "@components/About.astro";
import Projects from "@components/Projects.astro";
import SpecialtyCard from "@components/SpecialtyCard.astro";
import type { ServiceProps, SpecialtyCardProps } from "@types";
import { translations as t } from "@config/translations";

const navLinks = [
  { text: t.nav.projects, href: "#projects" },
  { text: t.nav.about, href: "#about" },
  { text: t.services.title, href: "#services" },
];

const socialLinks = [...t.footer.socialLinks];

const specialties = [
  t.about.specialties.design,
  t.about.specialties.speed,
  t.about.specialties.automation,
];
---

<Layout
  title={t.seo.title}
  description={t.seo.description}
  navLinks={navLinks}
  socialLinks={socialLinks}
  author={t.seo.author}
>
  <Hero
    name={t.hero.name}
    specialty={t.hero.specialty}
    summary={t.hero.summary}
    image={t.hero.image}
  />

  <div class="py-12"></div>

  <Projects
    title={t.projects.title}
    projects={t.projects.items}
    viewProject={t.projects.viewProject}
    viewCode={t.projects.viewCode}
  />

  <section class="py-20 relative" id="services">
    <div class="absolute inset-0 bg-primary/5 blur-[60px] -z-10"></div>
    <h2
      class="text-4xl font-serif text-cream text-center mb-16 tracking-widest uppercase opacity-0 translate-y-16 transition-all duration-1000"
      data-scroll-animation
    >
      {t.services?.title || "Servicios"}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        (t.services?.items || []).map((service: ServiceProps) => (
          <div
            class="group p-8 rounded-2xl bg-midnight/40 backdrop-blur-md border border-primary/10 opacity-0 translate-y-16 transition-all duration-1000 hover:shadow-aura hover:-translate-y-1 hover:bg-midnight/50"
            data-scroll-animation
          >
            <h3 class="text-2xl font-serif text-cream mb-4 transition-colors duration-500 group-hover:text-primary">
              {service.title}
            </h3>
            <p class="text-cream/70 font-light leading-relaxed">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="py-20 relative">
    <div class="absolute inset-0 bg-primary/5 blur-[60px] -z-10"></div>
    <h2
      class="text-4xl font-serif text-cream text-center mb-16 tracking-widest uppercase opacity-0 translate-y-16 transition-all duration-1000"
      data-scroll-animation
    >
      {t.specialties.title}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {
        t.specialties.items.map((item: SpecialtyCardProps) => (
          <SpecialtyCard
            title={item.title}
            description={item.description}
            icon={item.icon}
          />
        ))
      }
    </div>
  </section>

  <About
    title={t.about.title}
    description={t.about.description}
    greeting={t.about.greeting}
    specialtiesTitle={t.about.specialties.title}
    specialties={specialties}
    closing={t.about.closing}
    cta={t.about.cta}
    name={t.hero.name}
    image={t.about.image}
  />
</Layout>
