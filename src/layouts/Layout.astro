---
/**
 * Layout principal con soporte para i18n y SEO hreflang
 */
import { ViewTransitions } from "astro:transitions";
import Header from "@components/Header.astro";
import LanguagePicker from "@components/LanguagePicker.astro";
import "@fontsource/be-vietnam-pro";
import "@fontsource-variable/gabarito";
import Footer from "@components/Footer.astro";
import ScrollToTop from "@components/ScrollToTop.astro";
import type { Locale } from "../i18n/ui";

interface Props {
  title: string;
  description: string;
  locale: Locale;
  navLinks: { text: string; href: string }[];
  socialLinks: { text: string; href: string }[];
  author: string;
}

const {
  title,
  description,
  locale,
  navLinks,
  socialLinks,
  author,
} = Astro.props;

const defaultSite = "https://pablomgdev.netlify.app";
const siteUrl = Astro.site?.href || defaultSite;
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href;
const alternateUrls = {
  es: siteUrl.endsWith("/") ? `${siteUrl}es/` : `${siteUrl}/es/`,
  en: siteUrl.endsWith("/") ? `${siteUrl}en/` : `${siteUrl}/en/`,
};
---

<!doctype html lang={locale} class="scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`${canonicalURL}vistaprevia.png`} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={`${canonicalURL}vistaprevia.png`} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={alternateUrls.es} />
    <link rel="alternate" hreflang="en" href={alternateUrls.en} />
    <link rel="alternate" hreflang="x-default" href={alternateUrls.es} />

    <ViewTransitions />
  </head>
  <body class="font-sans bg-space text-cream relative overflow-x-hidden">
    <div class="fixed inset-0 pointer-events-none -z-20">
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-nebula/20 via-space to-space"
      >
      </div>
      <div
        class="absolute inset-0 opacity-10"
        style="background-image: radial-gradient(white 0.5px, transparent 0); background-size: 50px 50px;"
      >
      </div>
    </div>

    <div class="fixed top-4 right-4 z-[200]" transition:animate="none">
      <LanguagePicker currentLocale={locale} />
    </div>

    <Header {navLinks} locale={locale} />
    <main class="max-w-3xl px-5 mx-auto relative" transition:animate="none">
      <slot />
    </main>
    <Footer {author} {socialLinks} />
    <ScrollToTop />
    <script>
      import { handleScrollAnimation } from "@scripts/scrollAnimation.ts";

      const setup = () => handleScrollAnimation();

      document.addEventListener("astro:page-load", setup);
    </script>
  </body>
</html>
