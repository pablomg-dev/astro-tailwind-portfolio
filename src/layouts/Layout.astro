---
import { ViewTransitions } from "astro:transitions";
import Header from "@components/Header.astro";
import "@fontsource/be-vietnam-pro";
import "@fontsource-variable/gabarito";
import Footer from "@components/Footer.astro";
import ScrollToTop from "@components/ScrollToTop.astro";

// Estilos para optimizar fuentes
const fontOptimizationStyles = `
  @font-face { font-display: swap; }
`;

interface Props {
  title: string;
  description: string;
  navLinks: { text: string; href: string }[];
  author: string;
}

const { title, description, navLinks, author } = Astro.props;

const defaultSite = "https://pablomgdev.netlify.app";
const siteUrl = Astro.site?.href || defaultSite;
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="es-AR" class="scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Preconnect para fuentes locales -->
    <link rel="preconnect" href="/fonts/" crossorigin />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL("/vistaprevia.png", siteUrl)} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL("/vistaprevia.png", siteUrl)} />

    <meta
      name="keywords"
      content="Desarrollador Web Freelance Argentina, Programador Web Freelance, Desarrollo Web a Medida, Crear Página Web Profesional, Diseño y Desarrollo Web, Desarrollador React Argentina, Landing Page Profesional, Web para Emprendedores, Ecommerce a Medida, Sitio Web para Empresas"
    />

    <meta property="og:locale" content="es_AR" />

    <link rel="canonical" href={canonicalURL} />

    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Pablo M.G.",
        "url": "https://pablomgdev.lat",
        "jobTitle": "Desarrollador Web Freelance",
        "knowsAbout": [
          "React",
          "Astro",
          "Next.js",
          "Desarrollo Web",
          "Landing Pages",
          "Ecommerce",
          "MercadoPago"
        ],
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Buenos Aires",
          "addressCountry": "AR"
        },
        "sameAs": [
          "https://www.linkedin.com/in/pablomgdev/",
          "https://github.com/pablomg-dev"
        ]
      }
    </script>

    <ViewTransitions />
  </head>
  <body class="font-sans bg-space text-cream relative overflow-x-hidden">
    <div class="fixed inset-0 pointer-events-none -z-20">
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-nebula/20 via-space to-space"
      >
      </div>
      <div
        class="absolute inset-0 opacity-10"
        style="background-image: radial-gradient(white 0.5px, transparent 0); background-size: 50px 50px;"
      >
      </div>
    </div>

    <Header {navLinks} />
    <main class="max-w-3xl px-5 mx-auto relative" transition:animate="none">
      <slot />
    </main>
    <Footer {author} />
    <ScrollToTop />
    <script>
      import { handleScrollAnimation } from "@scripts/scrollAnimation.ts";

      const setup = () => handleScrollAnimation();

      document.addEventListener("astro:page-load", setup);
    </script>
  </body>
</html>
